# =============================================================================
# Africa Tech - Racine web (pages PHP à la racine + assets/api/uploads dans public/)
# =============================================================================

DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Bloquer l'accès au dossier logs.
    RewriteRule ^logs(?:/|$) - [F,L]

    # URL canonique sans extension: /about.php -> /about
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php(?:[\s?]|$) [NC]
    RewriteCond %1 !^(index|sitemap|admin|admin-gallery)$ [NC]
    RewriteRule ^ %1 [R=301,L,NE]

    # Servir les fichiers/répertoires réels sans réécriture.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Exposer assets/api/uploads/robots.txt depuis public/ sans déplacer les dossiers.
    RewriteRule ^(assets|api|uploads)/(.*)$ public/$1/$2 [L,NC]
    RewriteRule ^robots\.txt$ public/robots.txt [L,NC]

    # sitemap.xml -> sitemap.php
    RewriteRule ^sitemap\.xml$ sitemap.php [L,NC]

    # URL propre vers script PHP: /about -> /about.php
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>

# Fichiers sensibles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
